# ============================================================================
# IELTS Mock-Test Platform — environment variables
# Copy this file to ".env" at the repo root and fill in real values.
# Both frontend and backend read from this single root .env file.
#
#   cp .env.example .env
#
# NEVER commit the real .env. Secrets marked (server-only) must NEVER be
# exposed to the browser / placed in a NEXT_PUBLIC_* variable.
# ============================================================================

# ---------------------------------------------------------------------------
# Ports (local dev)
# ---------------------------------------------------------------------------
WEB_PORT=3099
API_PORT=4099

# Public URL of the backend API, used by the Next.js frontend (browser-safe).
NEXT_PUBLIC_API_URL=http://localhost:4099

# Public URL of the frontend, used by the backend for CORS + OAuth redirects.
WEB_ORIGIN=http://localhost:3099

# ---------------------------------------------------------------------------
# Supabase  (Project Settings -> API)
# ---------------------------------------------------------------------------
# Public — safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — full DB access, BYPASSES Row Level Security. Backend only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only — used by the backend to verify incoming Supabase JWTs.
# Supabase: Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ---------------------------------------------------------------------------
# Database (Prisma -> Supabase Postgres)
# Project Settings -> Database -> Connection string
# ---------------------------------------------------------------------------
# Pooled connection (Supavisor, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-ref:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (port 5432) — used by Prisma Migrate only.
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-ref:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# OpenRouter (LLM)  — server-only
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-your-openrouter-key
# Default model used for generation/grading (overridable per profile).
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
# Tiered models for billable actions. New users (still on welcome credits) run
# silently on FREE_MODEL; the moment their first top-up completes they are
# upgraded to PAID_MODEL automatically. Fully server-side — the user never sees
# or chooses a model. Credit prices are calibrated to PAID_MODEL.
PAID_MODEL=anthropic/claude-sonnet-4.6
FREE_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Credits granted once to each brand-new wallet (the free-model trial budget).
WELCOME_CREDITS=30

# ---------------------------------------------------------------------------
# Text-to-Speech (OpenAI) — server-only
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
NODE_ENV=development
# Where generated/cached audio files are written (served by the backend).
AUDIO_CACHE_DIR=.cache/audio
